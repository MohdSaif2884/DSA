class Solution {
public:
    vector<int> dailyTemperatures(vector<int>& teperatmures) {
    int n = teperatmures.size();

    stack<int>st;
    vector<int>res(n);

    for(int i = n -1 ; i>=0; i--){

        while(!st.empty() && teperatmures[i] >= teperatmures[st.top()]){
            st.pop();
        }
        if(st.empty()){
            res[i] =0;
        }else{
            res[i] = st.top()-i;
        }  st.push(i);
    }
   return res;
    }
};
